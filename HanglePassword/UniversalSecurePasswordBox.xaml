<UserControl x:Class="HanglePassword.SimpleHangulPassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="35" Width="250" Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
    <Grid>
        <TextBlock x:Name="MaskDisplay" 
                   FontSize="18" 
                   FontFamily="Consolas" 
                   Foreground="Black" 
                   Padding="0" Margin="5,0,0,0"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

        <Canvas IsHitTestVisible="False" Margin="5,0,0,0" VerticalAlignment="Center">
            <Border x:Name="FakeSelection" Background="#AA0078D7" Height="22" Visibility="Collapsed" Canvas.Top="-11"/>

            <Border x:Name="FakeCaret" Width="1.2" Height="18" Background="Black" Visibility="Hidden" Canvas.Top="-9">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </Canvas>

        <TextBox x:Name="RealInputBox"
                 FontSize="18"
                 FontFamily="Consolas"
                 Padding="0" Margin="5,0,0,0"
                 Background="Transparent" 
                 Foreground="Transparent"  
                 CaretBrush="Transparent"  BorderThickness="0"
                 SelectionBrush="{x:Null}" 
                 SelectionOpacity="0"
                 VerticalContentAlignment="Center"
                 TextChanged="RealInputBox_TextChanged"
                 PreviewKeyDown="RealInputBox_PreviewKeyDown"
                 SelectionChanged="RealInputBox_SelectionChanged" 
                 GotKeyboardFocus="RealInputBox_GotKeyboardFocus"
                 LostKeyboardFocus="RealInputBox_LostKeyboardFocus"
                 ContextMenu="{x:Null}"/>
    </Grid>
</UserControl>